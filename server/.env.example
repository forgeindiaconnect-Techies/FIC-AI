# Server Configurations
PORT=5001
CLIENT_URL=http://localhost:5182

# Database Configuration
MONGODB_URI=your_mongodb_connection_string

# AI Providers (Optional but recommended for intelligent poster layout text)
# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# OpenRouter API Key (Alternative AI provider)
OPENROUTER_API_KEY=your_openrouter_api_key

# Background Image Search API (Pexels) - Critical for loading backgrounds
PEXELS_API_KEY=your_pexels_api_key

# Cloudinary Configs for Logo Upload
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AI Image Editing Providers (Replicate, OpenAI, or Hugging Face)
# REPLICATE_API_TOKEN=your_replicate_api_token
# OPENAI_API_KEY=your_openai_api_key
# HF_API_KEY=your_hugging_face_api_token

